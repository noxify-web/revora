{
  "name": "revora",
  "version": "0.0.1",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:stable": "bash scripts/dev-stable.sh",
    "build": "next build",
    "start": "next start",
    "lint": "cd .. && bun run check",
    "format": "cd .. && bun run fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate-local": "bun run scripts/migrate-sqlite-to-turso.ts",
    "db:reset": "bun run scripts/reset-dev-data.ts"
  },
  "dependencies": {
    "@revora/shared": "workspace:*",
    "@libsql/client": "^0.17.4",
    "@shopify/app-bridge-types": "^0.7.1",
    "@shopify/shopify-api": "^13.0.0",
    "@shopify/shopify-app-session-storage": "^5.0.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shopify/polaris-types": "^1.0.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
