{%- comment -%}
  App-owned product metafields use the `app` Liquid namespace in theme app extensions.
  JSON metafield `.value` is a parsed object — serialize with the `json` filter for JS.
{%- endcomment -%}
{%- assign revora_reviews_metafield = product.metafields.app.revora_reviews_json -%}
{%- if revora_reviews_metafield == blank -%}
  {%- assign revora_reviews_metafield = product.metafields["$app"].revora_reviews_json -%}
{%- endif -%}
{%- assign revora_reviews_payload = revora_reviews_metafield.value -%}
{%- if revora_reviews_payload != blank -%}
  <script type="application/json" data-revora-initial-reviews>{{ revora_reviews_payload | json }}</script>
{%- endif -%}