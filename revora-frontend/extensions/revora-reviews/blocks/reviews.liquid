{% if product %}
  <div
    id="revora-reviews-root-{{ block.id }}"
    class="revora-reviews-root"
    data-shop="{{ shop.permanent_domain }}"
    data-product-id="{{ product.id }}"
    data-mode="full"
    data-limit="{{ block.settings.max_reviews | default: 10 }}"
    data-i18n-count="{{ 'revora.reviews_count' | t: count: '__COUNT__' | escape }}"
    data-i18n-empty="{{ 'revora.no_reviews' | t | escape }}"
    data-i18n-customer="{{ 'revora.customer' | t | escape }}"
    data-i18n-photo-alt="{{ 'revora.review_photo_alt' | t | escape }}"
    data-i18n-loading="{{ 'revora.loading_reviews' | t | escape }}"
    data-i18n-sort-label="{{ 'revora.sort_label' | t | escape }}"
    data-i18n-sort-recent="{{ 'revora.sort_recent' | t | escape }}"
    data-i18n-sort-highest="{{ 'revora.sort_highest' | t | escape }}"
    data-i18n-sort-lowest="{{ 'revora.sort_lowest' | t | escape }}"
    data-i18n-sort-helpful="{{ 'revora.sort_helpful' | t | escape }}"
    data-i18n-photos-only="{{ 'revora.photos_only' | t | escape }}"
    data-i18n-helpful="{{ 'revora.helpful' | t | escape }}"
    data-i18n-not-helpful="{{ 'revora.not_helpful' | t | escape }}"
    data-i18n-write-review="{{ 'revora.write_review' | t | escape }}"
    data-i18n-form-title="{{ 'revora.form_title' | t | escape }}"
    data-i18n-form-name="{{ 'revora.form_name' | t | escape }}"
    data-i18n-form-email="{{ 'revora.form_email' | t | escape }}"
    data-i18n-form-rating="{{ 'revora.form_rating' | t | escape }}"
    data-i18n-form-submit="{{ 'revora.form_submit' | t | escape }}"
    data-i18n-form-success="{{ 'revora.form_success' | t | escape }}"
  ></div>

  <script src="{{ 'revora-widget.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "t:blocks.reviews.name",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "range",
      "id": "max_reviews",
      "label": "t:blocks.reviews.settings.max_reviews.label",
      "min": 3,
      "max": 30,
      "step": 1,
      "default": 10
    }
  ]
}
{% endschema %}