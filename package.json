{
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "ultracite": "7.8.3"
  },
  "name": "revora-monorepo",
  "scripts": {
    "dev": "cd revora-frontend && bun run dev:stable",
    "dev:stable": "cd revora-frontend && bun run dev:stable",
    "install:frontend": "cd revora-frontend && bun install",
    "extension:dev": "cd revora-extension && bun run dev",
    "extension:build": "cd revora-extension && bun run build",
    "extension:test": "cd revora-extension && bun run test",
    "shared:test": "cd packages/revora-shared && bun run test",
    "extension:typecheck": "cd revora-extension && bun run typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "lint": "ultracite check"
  },
  "workspaces": [
    "revora-frontend",
    "revora-extension",
    "packages/*"
  ],
  "private": true,
  "packageManager": "bun@1.3.14"
}
